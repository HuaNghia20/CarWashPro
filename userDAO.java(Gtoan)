    public void addPoints(int custID, int points) {
    // Đảm bảo tên cột 'point' và bảng 'Customers' trong SQL của bạn giống hệt như thế này
    String sql = "UPDATE Customers SET point = ISNULL(point, 0) + ? WHERE CustomerID = ?";
    try (Connection cn = DBContext.getConnection(); PreparedStatement st = cn.prepareStatement(sql)) {
        st.setInt(1, points);
        st.setInt(2, custID);
        int rows = st.executeUpdate();
        System.out.println("Debug: Đã cập nhật thành công " + rows + " dòng điểm cho khách " + custID);
    } catch (Exception e) {
        e.printStackTrace(); // Nếu lỗi SQL nó sẽ hiện ở cửa sổ Output
    }
}
    public void updateTier(int custID, int tierID) {
        String sql = "UPDATE Customers SET TierID = ? WHERE CustomerID = ?";
        try (Connection cn = DBContext.getConnection(); PreparedStatement st = cn.prepareStatement(sql)) {
            st.setInt(1, tierID);
            st.setInt(2, custID);
            st.executeUpdate();
        } catch (Exception e) { 
            e.printStackTrace(); 
        }
    }
