<%@page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@page import="model.Promotion, model.User, java.util.List"%>
<%
    // Kiểm tra đăng nhập admin ngay đầu trang
    User user = (User) session.getAttribute("USER");
    if (user == null || !"ADMIN".equalsIgnoreCase(user.getRole())) {
        response.sendRedirect(request.getContextPath() + "/login_page.jsp");
        return;
    }
    String ctx = request.getContextPath();

    // Danh sách khuyến mãi (Servlet đã nạp sẵn)
    List<Promotion> promoList = (List<Promotion>) request.getAttribute("PROMO_LIST");

    // Nếu đang Sửa thì có đối tượng này, không thì null (tức đang Tạo mới)
    Promotion edit = (Promotion) request.getAttribute("EDIT_PROMO");
    boolean editing = (edit != null);

    // Thông báo (đọc xong xóa để không hiện lại)
    String msg = (String) session.getAttribute("MESSAGE");
    if (msg != null)
        session.removeAttribute("MESSAGE");
%>
<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>Quản lý khuyến mãi - Admin</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    </head>
    <body class="bg-dark text-light p-4">

        <div class="container">

            <h2 class="mb-4">Quản lý Khuyến mãi theo hạng</h2>

            <%-- Thông báo --%>
            <% if (msg != null) {%>
            <div class="alert alert-info"><%= msg%></div>
            <% }%>

            <%-- ============ FORM TẠO / SỬA ============ --%>
            <div class="card bg-secondary text-light mb-4">
                <div class="card-body">
                    <h5><%= editing ? "Sửa khuyến mãi #" + edit.getPromoID() : "Tạo khuyến mãi mới"%></h5>

                    <form action="<%= ctx%>/admin/promotions" method="post">
                        <%-- promoID = 0 nghĩa là tạo mới ; > 0 nghĩa là sửa --%>
                        <input type="hidden" name="promoID"  value="<%= editing ? edit.getPromoID() : 0%>">
                        <input type="hidden" name="rewardID" value="<%= editing ? edit.getRewardID() : 0%>">

                        <div class="mb-2">
                            <label>Tên khuyến mãi</label>
                            <input type="text" name="title" class="form-control"
                                   value="<%= editing ? edit.getTitle() : ""%>" required>
                        </div>

                        <div class="mb-2">
                            <label>Mô tả</label>
                            <input type="text" name="description" class="form-control"
                                   value="<%= editing && edit.getDescription() != null ? edit.getDescription() : ""%>">
                        </div>

                        <div class="row">
                            <div class="col mb-2">
                                <label>Số điểm cần đổi</label>
                                <input type="number" name="pointsRequired" class="form-control"
                                       value="<%= editing ? edit.getPointsRequired() : 300%>" required>
                            </div>
                            <div class="col mb-2">
                                <label>% Giảm giá</label>
                                <input type="number" name="discountPercent" class="form-control"
                                       value="<%= editing ? edit.getDiscountPercent() : 10%>" required>
                            </div>
                        </div>

                        <div class="mb-2">
                            <label>Gửi cho hạng tối thiểu</label>
                            <select name="minTierID" class="form-select">
                                <% int t = editing ? edit.getMinTierID() : 2;%>
                                <option value="1" <%= t == 1 ? "selected" : ""%>>Đồng trở lên (tất cả)</option>
                                <option value="2" <%= t == 2 ? "selected" : ""%>>Bạc trở lên</option>
                                <option value="3" <%= t == 3 ? "selected" : ""%>>Vàng trở lên</option>
                                <option value="4" <%= t == 4 ? "selected" : ""%>>Bạch Kim</option>
                            </select>
                        </div>

                        <div class="row">
                            <div class="col mb-2">
                                <label>Ngày bắt đầu</label>
                                <input type="date" name="startDate" class="form-control"
                                       value="<%= editing && edit.getStartDate() != null ? edit.getStartDate().toString() : ""%>">
                            </div>
                            <div class="col mb-2">
                                <label>Ngày kết thúc</label>
                                <input type="date" name="endDate" class="form-control"
                                       value="<%= editing && edit.getEndDate() != null ? edit.getEndDate().toString() : ""%>">
                            </div>
                        </div>

                        <div class="form-check mb-3">
                            <input type="checkbox" name="isActive" class="form-check-input" id="act"
                                   <%= (!editing || edit.isIsActive()) ? "checked" : ""%>>
                            <label class="form-check-label" for="act">Đang hoạt động (hiện ở trang Đổi điểm)</label>
                        </div>

                        <button type="submit" class="btn btn-warning">
                            <%= editing ? "Cập nhật" : "Tạo mới"%>
                        </button>
                        <% if (editing) {%>
                        <a href="<%= ctx%>/admin/promotions" class="btn btn-outline-light">Hủy</a>
                        <% } %>
                    </form>
                </div>
            </div>

            <%-- ============ DANH SÁCH KHUYẾN MÃI ============ --%>
            <table class="table table-dark table-striped">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tên</th>
                        <th>Điểm</th>
                        <th>Giảm</th>
                        <th>Hạng</th>
                        <th>Trạng thái</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <%
                        if (promoList != null && !promoList.isEmpty()) {
                            for (Promotion p : promoList) {
                    %>
                    <tr>
                        <td><%= p.getPromoID()%></td>
                        <td><%= p.getTitle()%></td>
                        <td><%= p.getPointsRequired()%></td>
                        <td><%= p.getDiscountPercent()%>%</td>
                        <td><%= p.getMinTierName()%>+</td>
                        <td><%= p.isIsActive() ? "Đang bật" : "Đã tắt"%></td>
                        <td>
                            <a href="<%= ctx%>/admin/promotions?action=edit&id=<%= p.getPromoID()%>"
                               class="btn btn-sm btn-warning">Sửa</a>
                        </td>
                    </tr>
                    <%
                        }
                    } else {
                    %>
                    <tr><td colspan="7" class="text-center">Chưa có khuyến mãi nào.</td></tr>
                    <% }%>
                </tbody>
            </table>

            <a href="<%= ctx%>/index.jsp" class="btn btn-outline-light">Về trang chủ</a>

        </div>
    </body>
</html>
