<%@page contentType="text/html" pageEncoding="UTF-8"%>
<%@page import="java.util.ArrayList"%>
<%@page import="model.Booking"%>
<%@page import="model.User"%>
<%
    // Đảm bảo an toàn tầng giao diện
    User user = (User) session.getAttribute("USER");
    if(user == null || !"ADMIN".equalsIgnoreCase(user.getRole())){
        response.sendRedirect("login_page.jsp");
        return;
    }
    
    ArrayList<Booking> allBookings = (ArrayList<Booking>) request.getAttribute("ALL_BOOKINGS");
    Integer totalBookings = (Integer) request.getAttribute("TOTAL_BOOKINGS");
    Double totalRevenue = (Double) request.getAttribute("TOTAL_REVENUE");
    Integer pendingCount = (Integer) request.getAttribute("PENDING_COUNT");
%>
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Admin Control Panel - CarWash Pro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --bg-main: #0a0b0d;
            --bg-card: #14161a;
            --border-color: #2a2d35;
            --yellow-accent: #ffcc00;
            --yellow-glow: rgba(255, 204, 0, 0.2);
            --text-main: #e0e4e8;
        }
        body { background-color: var(--bg-main); color: var(--text-main); padding: 30px; }
        .admin-card { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: 16px; padding: 20px; }
        .stat-card { border-left: 4px solid var(--yellow-accent); }
        .stat-number { font-size: 1.8rem; font-weight: 800; color: var(--yellow-accent); }
        th { color: var(--yellow-accent) !important; }
        .sidebar-link { color: var(--text-main); text-decoration: none; padding: 10px 15px; display: block; border-radius: 8px; transition: 0.3s; }
        .sidebar-link:hover, .sidebar-link.active { background: var(--yellow-accent); color: #000; font-weight: bold; }
    </style>
</head>
<body>

<div class="container-fluid">
    <div class="row">
        <div class="col-md-2 mb-4">
            <div class="admin-card">
                <h4 class="text-center mb-4" style="color: var(--yellow-accent); font-weight:900;">
                    <i class="fa-solid fa-user-gear"></i> WASH ADMIN
                </h4>
                <hr style="border-color: var(--border-color)">
                <nav class="nav flex-column gap-2">
                    <a class="sidebar-link active" href="AdminServlet"><i class="fa-solid fa-chart-pie me-2"></i> Tổng quan</a>
                    <a class="sidebar-link" href="ManageRewardsServlet"><i class="fa-solid fa-gift me-2"></i> Kho phần thưởng</a>
                   <a class="sidebar-link" href="${pageContext.request.contextPath}/index.jsp">
    <i class="fa-solid fa-arrow-right-from-bracket me-2"></i> Xem Trang Web
</a>
                </nav>
            </div>
        </div>

        <div class="row g-3 mb-4">
    <!-- KHỐI 1: TỔNG DOANH THU -->
    <div class="col-md-4">
        <div class="admin-card stat-card">
            <div class="text-white fw-bold text-uppercase small">Tổng doanh thu hệ thống</div>
            <div class="stat-number mt-1"><%= String.format("%,.0f", totalRevenue != null ? totalRevenue : 0) %> VNĐ</div>
        </div>
    </div>
    
    <!-- KHỐI 2: TỔNG LƯỢT ĐẶT LỊCH -->
    <div class="col-md-4">
        <div class="admin-card stat-card">
            <div class="text-white fw-bold text-uppercase small">Tổng số lượt đặt lịch</div>
            <div class="stat-number mt-1"><%= totalBookings != null ? totalBookings : 0 %> Lượt</div>
        </div>
    </div>
    
    <!-- KHỐI 3: LỊCH PENDING -->
    <div class="col-md-4">
        <div class="admin-card stat-card" style="border-left-color: orange;">
            <div class="text-warning fw-bold text-uppercase small">Lịch chưa xử lý (Pending)</div>
            <div class="stat-number mt-1 text-warning"><%= pendingCount != null ? pendingCount : 0 %> Lịch</div>
        </div>
    </div>
</div>

            <div class="admin-card">
                <h3 class="mb-4" style="font-weight: 700;"><i class="fa-solid fa-list-check text-warning"></i> Danh Sách Điều Hành Rửa Xe</h3>
                <div class="table-responsive">
                    <table class="table table-dark table-hover table-bordered align-middle">
                        <thead>
                            <tr>
                                <th>ID</th><th>Biển Số Xe</th><th>Gói Rửa Xe</th><th>Ngày Đặt</th><th>Khung Giờ</th><th>Chi Phí</th><th>Trạng Thái</th><th>Hành Động</th>
                            </tr>
                        </thead>
                        <tbody>
                        <!-- Tìm đoạn <tbody> trong file admin_dashboard.jsp của bạn và thay thế bằng đoạn này -->
<tbody>
<% if(allBookings != null && !allBookings.isEmpty()){
    for(Booking b : allBookings){ %>
    <tr>
        <td><%= b.getBookingID() %></td>
        <td><span class="badge bg-light text-dark fw-bold"><%= b.getLicensePlate() %></span></td>
        <td><%= b.getServiceType() %></td>
        <td><%= b.getBookingDate() %></td>
        <td><%= b.getBookingTime() %></td>
        <td><%= String.format("%,.0f", b.getPrice()) %> đ</td>
        <td>
            <%-- Dùng biến b.getStatus() nhưng logic CSS cần khớp với từ khóa trong DB --%>
            <span class="fw-bold text-<%= "Pending".equalsIgnoreCase(b.getStatus()) ? "warning" : "success" %>">
                <%= b.getStatus() %>
            </span>
        </td>
        <td>
            <%-- Đảm bảo kiểm tra đúng trạng thái "Pending" --%>
            <% if("Pending".equalsIgnoreCase(b.getStatus())){ %>
                <a href="AdminServlet?action=approve&id=<%= b.getBookingID() %>" class="btn btn-warning btn-sm fw-bold">
                    <i class="fa-solid fa-check"></i> Duyệt lịch
                </a>
            <% } else { %>
                <span class="text-muted small">Đã xử lý</span>
            <% } %>
        </td>
    </tr>
<% } } else { %>
    <tr><td colspan="8" class="text-center text-muted">Hệ thống chưa ghi nhận lịch đặt nào.</td></tr>
<% } %>
</tbody>
