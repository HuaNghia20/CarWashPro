<%@page contentType="text/html" pageEncoding="UTF-8"%>
<%@page import="java.util.ArrayList"%>
<%@page import="model.Booking"%>
<%@page import="model.User"%>

<%
    User user = (User) session.getAttribute("USER");
    if(user == null){
        response.sendRedirect("login_page.jsp");
        return;
    }
    ArrayList<Booking> bookingList = (ArrayList<Booking>) request.getAttribute("BOOKING_LIST");
%>

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Lịch Sử Booking</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <style>
        :root{ --bg-main:#0a0b0d; --bg-card:#14161a; --yellow:#ffcc00; --border:#2a2d35; --text:#e0e4e8; }
        body{ background:var(--bg-main); color:var(--text); padding:40px; }
        .card-custom{ background:var(--bg-card); border:1px solid var(--border); border-radius:16px; padding:25px; }
        .title{ color:var(--yellow); font-weight:bold; text-align:center; margin-bottom:25px; }
        table{ color:white !important; } th{ color:var(--yellow); }
        .btn-back{ text-decoration:none; color:#999; margin-bottom:20px; display:inline-block; }
        .status-pending{ color:orange; font-weight:bold; }
        .status-confirmed{ color:limegreen; font-weight:bold; }
        .status-completed{ color:#32cd32; font-weight:bold; }
        .status-cancelled{ color:red; font-weight:bold; }
        .payment-paid{ color:limegreen; font-weight:bold; }
        .payment-unpaid{ color:orange; font-weight:bold; }
        .payment-refunded{ color:cyan; font-weight:bold; }
    </style>
</head>
<body>

<div class="container">
    <a href="index.jsp" class="btn-back">← Quay lại trang chủ</a>
    <div class="card-custom">
        <h1 class="title">Lịch Sử Đặt Lịch</h1>
        <div class="table-responsive">
            <table class="table table-dark table-hover table-bordered align-middle">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Biển số xe</th>
                        <th>Dịch vụ</th>
                        <th>Ngày đặt</th>
                        <th>Giờ đặt</th>
                        <th>Giá</th>
                        <th>Trạng thái</th>
                        <th>Thanh toán</th> <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                <% if(bookingList != null && !bookingList.isEmpty()){
                    for(Booking b : bookingList){ %>
                    <tr>
                        <td><%= b.getBookingID() %></td>
                        <td><%= b.getLicensePlate() %></td>
                        <td><%= b.getServiceType() %></td>
                        <td><%= b.getBookingDate() %></td>
                        <td><%= b.getBookingTime() %></td>
                        <td><%= String.format("%,.0f", b.getPrice()) %> VNĐ</td>
                        <td>
                            <% String s = b.getStatus(); %>
                            <span class="status-<%=s != null ? s.toLowerCase().trim() : "pending"%>"><%=s%></span>
                        </td>
                        <td>
                            <% String p = b.getPaymentStatus(); %>
                            <span class="payment-<%=p != null ? p.toLowerCase().trim() : "unpaid"%>"><%=p%></span>
                        </td>
                        <td>
                            <% 
                                String currentStatus = b.getStatus() != null ? b.getStatus().trim() : "";
                                // ĐÃ SỬA: Cho phép hiển thị nút Hủy lịch khi trạng thái là Pending HOẶC Confirmed
                                if("Pending".equalsIgnoreCase(currentStatus) || "Confirmed".equalsIgnoreCase(currentStatus)){ 
                            %>
                                <button type="button" class="btn btn-danger btn-sm" 
                                        data-bs-toggle="modal" 
                                        data-bs-target="#confirmModal" 
                                        data-id="<%=b.getBookingID()%>">
                                    Hủy lịch
                                </button>
                            <% } else { %>
                                <span class="text-muted">Không khả dụng</span>
                            <% } %>
                        </td>
                    </tr>
                <% } } else { %>
                    <tr><td colspan="9" class="text-center">Chưa có lịch đặt nào.</td></tr>
                <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg"> <div class="modal-content" style="background:#14161a; border:1px solid #2a2d35; color:white;">
      <div class="modal-header border-0">
        <h5 class="modal-title">Xác nhận hủy lịch</h5>
      </div>
      <div class="modal-body">
          <p>Bạn có chắc chắn muốn hủy lịch đặt này không? Hệ thống sẽ tự động tính số tiền hoàn dựa trên thời gian tới giờ hẹn của bạn.</p>
          
          <div class="table-responsive mt-3">
              <table class="table table-dark table-bordered table-striped text-center align-middle mb-0">
                  <thead>
                      <tr>
                          <th scope="col" class="text-start">Thời gian tính đến giờ hẹn</th>
                          <th scope="col">Tỷ lệ hoàn tiền</th>
                          <th scope="col">Ưu đãi kèm theo</th>
                      </tr>
                  </thead>
                  <tbody>
                      <tr>
                          <td class="text-start">Trên 30 tiếng</td>
                          <td class="text-success fw-bold">100%</td>
                          <td>-</td>
                      </tr>
                      <tr>
                          <td class="text-start">Từ 24 - 30 tiếng</td>
                          <td class="text-success fw-bold">75%</td>
                          <td>-</td>
                      </tr>
                      <tr>
                          <td class="text-start">Từ 12 - 24 tiếng</td>
                          <td class="text-warning fw-bold">50%</td>
                          <td>-</td>
                      </tr>
                      <tr>
                          <td class="text-start">Từ 2 - 12 tiếng</td>
                          <td class="text-warning fw-bold">25%</td>
                          <td>-</td>
                      </tr>
                      <tr>
                          <td class="text-start">Từ 20 phút - 2 tiếng</td>
                          <td class="text-danger fw-bold">0%</td>
                          <td>-</td>
                      </tr>
                      <tr>
                          <td class="text-start">Dưới 20 phút hoặc quá giờ</td>
                          <td class="text-danger fw-bold">0%</td>
                          <td class="text-info">Tặng mã giảm giá 10%</td>
                      </tr>
                  </tbody>
              </table>
          </div>
          <p class="text-muted small mt-2 mb-0">
              * Lưu ý: Hệ thống sẽ tự động tính toán dựa trên thời gian thực tế lúc bạn bấm nút "Đồng ý hủy".
          </p>
          </div>
      <div class="modal-footer border-0">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
        <a href="#" id="confirmLink" class="btn btn-danger">Đồng ý hủy</a>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    var confirmModal = document.getElementById('confirmModal');
    confirmModal.addEventListener('show.bs.modal', function (event) {
        var button = event.relatedTarget;
        var id = button.getAttribute('data-id');
        var link = document.getElementById('confirmLink');
        
        // Điều hướng chuẩn tới Controller của bạn kèm tham số ID
        link.setAttribute('href', 'BookingHistoryServlet?action=cancel&id=' + id); 
        // Đã sửa lại đường dẫn thành BookingHistoryServlet?action=cancel theo đúng file logic mới nhất của bạn
    });
</script>

<%
    String messageAlert = (String) request.getAttribute("messageAlert");
    // Kiểm tra thêm session MESSAGE (Vì ở BookingHistoryServlet bạn lưu thông báo vào session.setAttribute("MESSAGE", ...))
    String sessionMsg = (String) session.getAttribute("MESSAGE"); 
    
    String finalMsg = null;
    if (messageAlert != null && !messageAlert.isEmpty()) finalMsg = messageAlert;
    else if (sessionMsg != null && !sessionMsg.isEmpty()) {
        finalMsg = sessionMsg;
        session.removeAttribute("MESSAGE"); // Xóa sau khi hiển thị để không bị báo lại khi F5
    }

    if (finalMsg != null) {
%>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            let msg = "<%= finalMsg %>";
          // Nếu thông báo có chữ 'hoàn lại', 'thành công' hoặc 'tặng bạn' -> Hiện icon success màu xanh
let iconType = (msg.includes("thành công") || msg.includes("tặng bạn") || msg.includes("hoàn lại")) ? "success" : "error";
            
            Swal.fire({
                title: 'Thông báo hệ thống',
                text: msg,
                icon: iconType,
                confirmButtonColor: '#ffcc00',
                confirmButtonText: 'Đóng'
            });
        });
    </script>
<%
    }
%>

</body>
</html>
