package dao;

import java.sql.Connection;
import java.sql.Date;
import java.sql.PreparedStatement;
import java.sql.ResultSet;
import model.User;
import utils.DBContext;

public class UserDAO {
    
    public static String lastError = "";

    public int createNewUser(User c){
        int result=0;
        Connection cn=null;
        try {
            cn=DBContext.getConnection();
            if(cn!=null){
                String sql = "insert dbo.Customers(FullName,Email,password,PhoneNumber,TierID,CreatedAt,Status) \n"
                        + "   values(?,?,?,?,?,?,?)";
                PreparedStatement st=cn.prepareStatement(sql);
                st.setString(1, c.getFullname());
                st.setString(2, c.getEmail());
                st.setString(3, c.getPassword());
                st.setString(4, c.getPhone()); 
                st.setInt(5, c.getTierID());
                st.setDate(6, c.getCreateAt());
                st.setBoolean(7, c.isStatus());
                result=st.executeUpdate();
            }
        } catch (Exception e) {
            // Hứng câu thông báo lỗi của SQL Server vào biến này
            lastError = e.getMessage(); 
            e.printStackTrace();
        }finally{
            try {
                if(cn!=null) cn.close();
            } catch (Exception e) {
                e.printStackTrace();
            }
        }
        return result;
    }

    public User getUser(String email, String password){
        User result=null;
        Connection cn=null;
        try {
            cn=DBContext.getConnection();
            if(cn!=null){
                // Đã đổi thành PhoneNumber ở câu lệnh SELECT
                String sql = "select [CustomerID],FullName,Email,password,PhoneNumber,TierID,CreatedAt,Status\n"
                        + "from dbo.Customers\n"
                        + "where Email=? and password=? ";
                PreparedStatement st=cn.prepareStatement(sql);
                st.setString(1, email);
                st.setString(2, password);
                
                ResultSet table= st.executeQuery();
                if(table!=null){
                    while(table.next()){
                        int cusid=table.getInt("CustomerID");
                        String name=table.getString("FullName");
                        int tierid=table.getInt("TierID");
                        Date date=table.getDate("CreatedAt");
                        boolean status=table.getBoolean("status");
                        // Đã đổi thành PhoneNumber khi lấy dữ liệu
                        String phone=table.getString("PhoneNumber"); 
                        
                        result=new User(cusid, name, phone, email, tierid, date, status, password);
                    }
                }
            }
        } catch (Exception e) {
            e.printStackTrace();
        } finally {
            try { if(cn!=null) cn.close(); } catch(Exception e) {}
        }      
        return result;
    }

   public User getUser(String email){
        User result=null;
        Connection cn=null;
        try {
            cn=DBContext.getConnection();
            if(cn!=null){
                // Bổ sung thêm cột Wallet vào câu SELECT
                String sql = "select [CustomerID],FullName,Email,password,PhoneNumber,TierID,CreatedAt,Status, Wallet\n"
                        + "from dbo.Customers\n"
                        + "where Email=?";
                PreparedStatement st=cn.prepareStatement(sql);
                st.setString(1, email);
                ResultSet table= st.executeQuery();
                if(table!=null){
                    while(table.next()){
                        int cusid=table.getInt("CustomerID");
                        String name=table.getString("FullName");
                        String password=table.getString("password");
                        int tierid=table.getInt("TierID");
                        Date date=table.getDate("CreatedAt");
                        boolean status=table.getBoolean("status");
                        String phone=table.getString("PhoneNumber"); 
                        
                        // Lấy thêm tiền ví từ DB
                        double wallet = table.getDouble("Wallet"); 
                        
                        result = new User(cusid, name, phone, email, tierid, date, status, password);
                        result.setWallet(wallet); // Nạp tiền vào User
                    }
                }
            }
        } catch (Exception e) {
            e.printStackTrace();
        } finally {
            try { if(cn!=null) cn.close(); } catch(Exception e) {}
        }
        return result;
    } 

    // --- CODE THÊM MỚI CHO WORKSHOP 1 ---
    
    // Đổi mật khẩu thành viên (TV2)
    public boolean changePassword(int custID, String newPassword) {
        String sql = "UPDATE dbo.Customers SET password = ? WHERE CustomerID = ?";
        try (Connection cn = DBContext.getConnection();
             PreparedStatement st = cn.prepareStatement(sql)) {
            st.setString(1, newPassword);
            st.setInt(2, custID);
            return st.executeUpdate() > 0;
        } catch (Exception e) {
            e.printStackTrace();
        }
        return false;
    }

    // Cập nhật Profile: Họ tên (TV2)
